# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Backend API URLs (optional)
# Leave these commented out to use the default nginx proxy (recommended for `make dev`)
# Only set these if you need to connect to backend services directly
# NEXT_PUBLIC_BACKEND_BASE_URL="http://localhost:8100"
# NEXT_PUBLIC_LANGGRAPH_BASE_URL="http://localhost:2024"

# Internal upstream for Next.js rewrites (required when NEXT_PUBLIC_BACKEND_BASE_URL is not set)
# Local `make dev` should point to 8100; Docker dev should point to gateway:8001
# DEER_FLOW_INTERNAL_GATEWAY_BASE_URL="http://127.0.0.1:8100"

# LangGraph API base URL
# Default: /api/langgraph-compat (Gateway-backed runtime, M5 identity HMAC works).
#   Started by `make dev-pro`; embeds the agent runtime in Gateway, no separate
#   LangGraph dev server.  This is the recommended deployment for self-hosted /
#   private installs because there's one fewer process to operate.
# Override to /api/langgraph for the 4-process standard mode (Gateway + LangGraph
#   dev server side-by-side, started by `make dev`).  Note: identity HMAC headers
#   are NOT injected on this path — only use it for LangSmith / LangGraph Studio
#   tooling integrations or for upstream parity testing.
# NEXT_PUBLIC_LANGGRAPH_BASE_URL=/api/langgraph

# Identity UI toggle
# Docker compose injects this automatically from ENABLE_IDENTITY. Only uncomment
# it for non-Docker local frontend development.
# NEXT_PUBLIC_ENABLE_IDENTITY=true
